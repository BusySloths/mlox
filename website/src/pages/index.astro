---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import NewsBanner from '../components/NewsBanner.astro';
import { getCollection } from 'astro:content';

// Get content from markdown files
const pages = await getCollection('pages');
const heroPage = pages.find(p => p.id === 'hero.md');
const featuresPage = pages.find(p => p.id === 'features.md');
const gettingStartedPage = pages.find(p => p.id === 'getting-started.md');
const whyMloxPage = pages.find(p => p.id === 'why-mlox.md');
const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;

// Render markdown content (only for sections that need it)
const heroContent = heroPage ? await heroPage.render() : null;
---

<BaseLayout title="MLOX - MLOps Made Simple">
  <Header />
  <NewsBanner />

  <style>
    :global(body) {
      --paper: #f6f1e6;
      --paper-alt: #e9dec7;
      --paper-bright: #fbf7ee;
      --ink: #1f1b16;
      --highlight: #d3a321;
      background: repeating-linear-gradient(
        -45deg,
        var(--paper),
        var(--paper) 14px,
        var(--paper-alt) 14px,
        var(--paper-alt) 28px
      );
    }

    .hero-container {
      transform: rotate(-1.5deg);
    }

    .hero-3d {
      border: 3px solid var(--ink);
      box-shadow: 8px 8px 0 var(--ink);
      transition: transform 0.2s ease;
      background: var(--paper-bright);
    }

    .hero-3d:hover {
      transform: translate(-3px, -3px);
      box-shadow: 11px 11px 0 var(--ink);
    }

    /* Enforce warm-paper surface colors over dark-mode-named utility classes */
    main :global(.bg-dark-900),
    main :global(.bg-dark-800),
    main :global(.bg-dark-700),
    main :global(.bg-dark-600) {
      background: var(--paper);
    }

    /* Enforce ink text color — theme is light, not dark */
    main :global(.text-white),
    main :global(.text-gray-400),
    main :global(.text-gray-300),
    main :global(.text-gray-200),
    main :global(.text-gray-500) {
      color: var(--ink);
    }

    main :global(.border-dark-600),
    main :global(.border-dark-700) {
      border-color: var(--ink);
      border-width: 2px;
    }

    main :global(.border-2) {
      border-width: 1.5px;
    }

    main :global(.border) {
      border-width: 1px;
    }

    main > section + section {
      border-top: 2px solid var(--ink);
    }

    h1, h2, h3, h4 {
      text-transform: uppercase;
      letter-spacing: -0.02em;
    }

    .prose {
      max-width: 70ch;
      font-weight: 500;
    }

    .prose strong {
      background: var(--highlight);
      padding: 0 4px;
    }
  </style>
  
  <main class="pt-24 md:pt-24 bg-dark-900">
    <!-- Hero Section -->
    <section class="relative min-h-screen flex items-center justify-center bg-dark-900">
      <div class="container mx-auto px-6 relative z-10">
        <div class="grid md:grid-cols-2 gap-12 items-center max-w-6xl mx-auto">
          <!-- Left: Hero text content -->
          <div class="text-left animate-fade-in">
            {heroPage && (
              <>
                <h1 class="text-5xl md:text-6xl font-bold mb-6 text-white animate-slide-up">
                  {heroPage.data.title}
                </h1>
                <p class="text-xl md:text-2xl text-gray-300 mb-8 animate-slide-up">
                  {heroPage.data.subtitle}
                </p>
              </>
            )}
            {heroPage && (
              <div class="flex flex-col sm:flex-row gap-4 animate-slide-up">
                <a
                  href={heroPage.data.cta_primary_link}
                  class="px-8 py-4 bg-accent-cyan text-ink border-2 border-ink font-black text-sm uppercase tracking-wider shadow-lg hover:translate-x-[-2px] hover:translate-y-[-2px] transition-transform duration-150 text-center"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {heroPage.data.cta_primary}
                </a>
                <a
                  href={heroPage.data.cta_secondary_link}
                  class="px-8 py-4 bg-paper-bright text-ink border-2 border-ink font-black text-sm uppercase tracking-wider shadow-lg hover:translate-x-[-2px] hover:translate-y-[-2px] transition-transform duration-150 text-center"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {heroPage.data.cta_secondary}
                </a>
              </div>
            )}
            <div class="flex flex-wrap gap-3 mt-12 animate-slide-up">
              <a href="https://qlty.sh/gh/BusySloths/projects/mlox" target="_blank" rel="noopener noreferrer" class="hover:translate-x-[-1px] hover:translate-y-[-1px] transition-transform duration-150">
                <img src="https://qlty.sh/gh/BusySloths/projects/mlox/maintainability.svg" alt="Maintainability" class="h-5" />
              </a>
              <a href="https://qlty.sh/gh/BusySloths/projects/mlox" target="_blank" rel="noopener noreferrer" class="hover:translate-x-[-1px] hover:translate-y-[-1px] transition-transform duration-150">
                <img src="https://qlty.sh/gh/BusySloths/projects/mlox/coverage.svg" alt="Code Coverage" class="h-5" />
              </a>
              <a href="https://github.com/BusySloths/mlox/issues" target="_blank" rel="noopener noreferrer" class="hover:translate-x-[-1px] hover:translate-y-[-1px] transition-transform duration-150">
                <img alt="GitHub Issues" src="https://img.shields.io/github/issues/busysloths/mlox" class="h-5" />
              </a>
              <a href="https://github.com/BusySloths/mlox/discussions" target="_blank" rel="noopener noreferrer" class="hover:translate-x-[-1px] hover:translate-y-[-1px] transition-transform duration-150">
                <img alt="GitHub Discussions" src="https://img.shields.io/github/discussions/busysloths/mlox" class="h-5" />
              </a>
            </div>
          </div>
          
          <!-- Right: Hero interface mockup image -->
          <div class="animate-fade-in animate-slide-up hero-container">
            <div class="relative overflow-hidden hero-3d border-2 border-ink hover:border-accent-cyan">
              <picture>
                <source srcset={`${baseUrl}mlox_sloth_logo.webp`} type="image/webp" />
                <img
                  src={`${baseUrl}mlox_sloth_logo.png`}
                  alt="MLOX Sloth Logo"
                  class="w-full h-auto"
                />
              </picture>
            </div>
          </div>
        </div>
      </div>

      <!-- Scroll indicator -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
        <svg class="w-6 h-6 text-accent-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="square" stroke-linejoin="miter" stroke-width="2.5" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
        </svg>
      </div>
    </section>

    {heroContent && (
      <section class="py-20 bg-dark-900">
        <div class="container mx-auto px-6">
          <div class="max-w-6xl mx-auto relative border-2 border-dark-600 bg-paper-bright p-8 md:p-12 shadow-xl overflow-hidden">
            <div class="absolute -top-10 -right-10 w-36 h-36 border-2 border-black bg-accent-cyan/30"></div>
            <div class="absolute -bottom-8 -left-8 w-24 h-24 border-2 border-black bg-accent-yellow/40"></div>

            <div class="relative z-10 grid lg:grid-cols-3 gap-8 md:gap-10 items-start">
              <div class="lg:col-span-2">
                <p class="inline-block text-xs font-black tracking-[0.18em] px-3 py-1 border border-black bg-accent-cyan text-black mb-5">
                  WHY TEAMS PICK MLOX
                </p>
                <h2 class="text-3xl md:text-4xl font-bold mb-6 text-black">
                  Calm Operations for Serious ML Systems
                </h2>
                <div class="text-lg text-black leading-relaxed prose prose-invert [&>p]:mb-4 max-w-none">
                  <heroContent.Content />
                </div>
              </div>

              <div class="space-y-4">
                <div class="border-2 border-black p-4 bg-accent-yellow/60">
                  <p class="text-xs font-black uppercase tracking-wider mb-1">Own Your Stack</p>
                  <p class="text-sm">Run on your own infrastructure with inspectable configs and no black boxes.</p>
                </div>
                <div class="border-2 border-black p-4 bg-accent-pink/35">
                  <p class="text-xs font-black uppercase tracking-wider mb-1">Operational Clarity</p>
                  <p class="text-sm">Web UI, TUI, and CLI stay aligned so teams can deploy and debug faster.</p>
                </div>
                <div class="border-2 border-black p-4 bg-accent-cyan/20">
                  <p class="text-xs font-black uppercase tracking-wider mb-1">Built To Evolve</p>
                  <p class="text-sm">Open-source foundations designed for long-term maintainability and adaptation.</p>
                </div>
              </div>
            </div>

            <div class="relative z-10 mt-8 grid sm:grid-cols-3 gap-4">
              <div class="border border-black bg-paper px-4 py-3 text-center">
                <p class="text-2xl font-black text-black">UI + TUI + CLI</p>
                <p class="text-xs uppercase tracking-wider">One Unified Control Surface</p>
              </div>
              <div class="border border-black bg-paper px-4 py-3 text-center">
                <p class="text-2xl font-black text-black">Open Source</p>
                <p class="text-xs uppercase tracking-wider">Transparent By Default</p>
              </div>
              <div class="border border-black bg-paper px-4 py-3 text-center">
                <p class="text-2xl font-black text-black">Hybrid Ready</p>
                <p class="text-xs uppercase tracking-wider">On-Prem Or Mixed Cloud</p>
              </div>
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- Features Section - Using Markdown Content -->
    <section id="features" class="py-20 bg-dark-800">
      <div class="container mx-auto px-6">
        {featuresPage && (
          <h2 class="text-4xl md:text-5xl font-bold text-center mb-16 text-white">
            {featuresPage.data.title}
          </h2>
        )}
        {featuresPage && featuresPage.data.features && (
          <div class="max-w-6xl mx-auto">
            <div class="grid md:grid-cols-3 gap-8">
              {featuresPage.data.features.map((feature) => {
                const stampBgClass = feature.color === 'cyan' ? 'bg-accent-cyan' :
                                     feature.color === 'purple' ? 'bg-accent-purple text-paper-bright' :
                                     'bg-accent-pink';
                return (
                  <div class="group p-8 bg-paper-bright border-2 border-ink shadow-lg hover:translate-x-[-2px] hover:translate-y-[-2px] transition-transform duration-150">
                    <div aria-hidden="true" class={`inline-flex items-center justify-center w-14 h-14 border-2 border-ink font-mono text-base font-black mb-6 ${stampBgClass}`}>
                      {feature.icon}
                    </div>
                    <h3 class="text-xl font-black mb-4 text-ink uppercase tracking-tight">{feature.title}</h3>
                    {feature.description && (
                      <p class="text-ink text-sm font-medium leading-relaxed mb-4">{feature.description}</p>
                    )}
                    <ul class="space-y-2 list-none border-t-2 border-ink pt-4">
                      {feature.items.map((item) => (
                        <li class="flex items-start text-ink text-sm leading-relaxed">
                          <span aria-hidden="true" class="font-black mr-2 mt-0.5 text-accent-green flex-shrink-0">→</span>
                          <span>{item}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                );
              })}
            </div>
          </div>
        )}
      </div>
    </section>

    <!-- Why MLOX Section - Flat Minimal Design -->
    {whyMloxPage && whyMloxPage.data.cards && (
      <section id="why-mlox" class="py-20 bg-dark-900 relative overflow-hidden">
        <!-- Subtle background pattern -->
        <div class="absolute inset-0 opacity-5">
          <div class="absolute top-0 left-0 w-full h-full" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 40px 40px;"></div>
        </div>
        
        <div class="container mx-auto px-6 relative z-10">
          <h2 class="text-4xl md:text-5xl font-bold text-center mb-16 text-white">
            {whyMloxPage.data.title}
          </h2>
          <div class="max-w-6xl mx-auto grid md:grid-cols-2 lg:grid-cols-4 gap-8">
            {whyMloxPage.data.cards.map((card, index) => {
              const stampBgClass = index % 4 === 0 ? 'bg-accent-yellow' :
                                   index % 4 === 1 ? 'bg-accent-green text-paper-bright' :
                                   index % 4 === 2 ? 'bg-accent-cyan' :
                                   'bg-accent-purple text-paper-bright';
              return (
                <div class="group border-2 border-ink p-6 bg-paper-bright shadow-lg hover:translate-x-[-2px] hover:translate-y-[-2px] transition-transform duration-150">
                  <div aria-hidden="true" class={`inline-flex items-center justify-center px-3 py-2 border-2 border-ink font-mono text-lg font-black mb-4 ${stampBgClass}`}>
                    {card.icon}
                  </div>
                  <h3 class="font-black text-sm mb-3 text-ink uppercase tracking-tight">{card.title}</h3>
                  <p class="text-ink text-sm leading-relaxed">{card.description}</p>
                </div>
              );
            })}
          </div>
          <div class="max-w-5xl mx-auto mt-16 rounded-2xl border border-accent-yellow/80 bg-accent-yellow px-5 py-5 text-center shadow-md">
            <p class="text-xs md:text-sm text-black font-semibold md:whitespace-nowrap">
              MLOX is under active development. Features and workflows continue to evolve. We welcome contributors and feedback.
            </p>
          </div>
        </div>
      </section>
    )}

    <!-- Screenshots Section -->
    <section id="screenshots" class="py-20 bg-dark-800">
      <div class="container mx-auto px-6">
        <h2 class="text-4xl md:text-5xl font-bold text-center mb-6 text-white">
          See MLOX in Action
        </h2>
        <p class="text-xl text-gray-400 text-center mb-16 max-w-3xl mx-auto">
          Experience the power of MLOX through our intuitive interface and comprehensive tooling
        </p>
        <div class="max-w-6xl mx-auto grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <!-- Screenshot 1: Infrastructure Control -->
          <div class="group relative overflow-hidden shadow-xl border-2 border-dark-600 hover:border-accent-pink transition-transform duration-150 hover:translate-x-[-2px] hover:translate-y-[-2px]">
            <picture>
              <source srcset={`${baseUrl}mlox_server.webp`} type="image/webp" />
              <img
                loading="lazy"
                src={`${baseUrl}mlox_server.png`}
                alt="MLOX Infrastructure Control"
                class="w-full h-auto"
              />
            </picture>
            <div class="absolute bottom-0 left-0 right-0 bg-ink border-t-2 border-ink px-4 py-3">
              <h3 class="text-paper-bright font-black text-sm uppercase tracking-wide">Infrastructure Control</h3>
              <p class="text-paper-alt text-xs mt-0.5">Manage servers and clusters with ease</p>
            </div>
          </div>


          <!-- Screenshot 2: Service Management -->
          <div class="group relative overflow-hidden shadow-xl border-2 border-dark-600 hover:border-accent-purple transition-transform duration-150 hover:translate-x-[-2px] hover:translate-y-[-2px]">
            <picture>
              <source srcset={`${baseUrl}mlox_services.webp`} type="image/webp" />
              <img
                loading="lazy"
                src={`${baseUrl}mlox_services.png`}
                alt="MLOX Service Management"
                class="w-full h-auto"
              />
            </picture>
            <div class="absolute bottom-0 left-0 right-0 bg-ink border-t-2 border-ink px-4 py-3">
              <h3 class="text-paper-bright font-black text-sm uppercase tracking-wide">Service Management</h3>
              <p class="text-paper-alt text-xs mt-0.5">Deploy and manage ML services effortlessly</p>
            </div>
          </div>


          <!-- Screenshot 3: Integration View -->
          <div class="group relative overflow-hidden shadow-xl border-2 border-dark-600 hover:border-accent-yellow transition-transform duration-150 hover:translate-x-[-2px] hover:translate-y-[-2px]">
            <picture>
              <source srcset={`${baseUrl}mlox_add_git_service.webp`} type="image/webp" />
              <img
                loading="lazy"
                src={`${baseUrl}mlox_add_git_service.png`}
                alt="MLOX GIT & Cloud Integrations"
                class="w-full h-auto"
              />
            </picture>
            <div class="absolute bottom-0 left-0 right-0 bg-ink border-t-2 border-ink px-4 py-3">
              <h3 class="text-paper-bright font-black text-sm uppercase tracking-wide">Git & Cloud Integrations</h3>
              <p class="text-paper-alt text-xs mt-0.5">Seamless integration with Git and Cloud Platforms</p>
            </div>
          </div>

          <!-- Screenshot 4: Monitoring -->
          <div class="group relative overflow-hidden shadow-xl border-2 border-dark-600 hover:border-accent-cyan transition-transform duration-150 hover:translate-x-[-2px] hover:translate-y-[-2px]">
            <picture>
              <source srcset={`${baseUrl}mlox_monitor.webp`} type="image/webp" />
              <img
                loading="lazy"
                src={`${baseUrl}mlox_monitor.png`}
                alt="MLOX Real-time Monitoring"
                class="w-full h-auto"
              />
            </picture>
            <div class="absolute bottom-0 left-0 right-0 bg-ink border-t-2 border-ink px-4 py-3">
              <h3 class="text-paper-bright font-black text-sm uppercase tracking-wide">Real-time Monitoring</h3>
              <p class="text-paper-alt text-xs mt-0.5">Track performance and metrics in real-time</p>
            </div>
          </div>
          <!-- Screenshot 5: Terminal UI -->
          <div class="group relative overflow-hidden shadow-xl border-2 border-dark-600 hover:border-accent-green transition-transform duration-150 hover:translate-x-[-2px] hover:translate-y-[-2px]">
            <picture>
              <source srcset={`${baseUrl}mlox_tui.webp`} type="image/webp" />
              <img
                loading="lazy"
                src={`${baseUrl}mlox_tui.png`}
                alt="MLOX TUI"
                class="w-full h-auto"
              />
            </picture>
            <div class="absolute bottom-0 left-0 right-0 bg-ink border-t-2 border-ink px-4 py-3">
              <h3 class="text-paper-bright font-black text-sm uppercase tracking-wide">Terminal UI</h3>
              <p class="text-paper-alt text-xs mt-0.5">Low bandwidth configuration management</p>
            </div>
          </div>

          <!-- Screenshot 6: CLI -->
          <div class="group relative overflow-hidden shadow-xl border-2 border-dark-600 hover:border-accent-cyan transition-transform duration-150 hover:translate-x-[-2px] hover:translate-y-[-2px]">
            <picture>
              <source srcset={`${baseUrl}mlox_cli.webp`} type="image/webp" />
              <img
                loading="lazy"
                src={`${baseUrl}mlox_cli.png`}
                alt="MLOX CLI"
                class="w-full h-auto"
              />
            </picture>
            <div class="absolute bottom-0 left-0 right-0 bg-ink border-t-2 border-ink px-4 py-3">
              <h3 class="text-paper-bright font-black text-sm uppercase tracking-wide">CLI</h3>
              <p class="text-paper-alt text-xs mt-0.5">Build for automation.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Getting Started Section - Card-based Steps -->
    <section id="get-started" class="py-20 bg-dark-900">
      <div class="container mx-auto px-6">
        {gettingStartedPage && (
          <>
            <h2 class="text-4xl md:text-5xl font-bold text-center mb-4 text-white">
              {gettingStartedPage.data.title}
            </h2>
            {gettingStartedPage.data.subtitle && (
              <h3 class="text-2xl md:text-3xl text-center mb-6 text-accent-cyan font-semibold">
                {gettingStartedPage.data.subtitle}
              </h3>
            )}
            {gettingStartedPage.data.description && (
              <p class="text-lg text-center mb-16 text-gray-400 max-w-3xl mx-auto">
                {gettingStartedPage.data.description}
              </p>
            )}
          </>
        )}
        
        <div class="max-w-6xl mx-auto">
          {gettingStartedPage?.data.steps && (
            <ol class="grid md:grid-cols-2 gap-8 list-none p-0 m-0">
              {gettingStartedPage.data.steps.map((step, index) => {
                const numberClass =
                  index % 4 === 0 ? 'bg-accent-cyan text-ink' :
                  index % 4 === 1 ? 'bg-accent-purple text-paper-bright' :
                  index % 4 === 2 ? 'bg-accent-pink text-ink' :
                  'bg-accent-yellow text-ink';

                return (
                  <li class="bg-paper-bright p-8 border-2 border-ink shadow-lg hover:translate-x-[-2px] hover:translate-y-[-2px] transition-transform duration-150">
                    <div class="flex items-start gap-4 mb-4">
                      <div aria-hidden="true" class={`${numberClass} w-12 h-12 border-2 border-ink flex items-center justify-center text-xl font-black flex-shrink-0`}>
                        {index + 1}
                      </div>
                      <div class="flex-1">
                        <h4 class="text-lg font-black text-ink mb-2 uppercase tracking-tight">{step.title}</h4>
                        <p class="text-ink text-sm leading-relaxed">{step.description}</p>
                      </div>
                    </div>

                    {step.code && (
                      <div class="mt-4">
                        <pre class="bg-ink text-accent-cyan px-4 py-3 text-sm font-mono border-2 border-ink overflow-x-auto"><code>{step.code}</code></pre>
                      </div>
                    )}

                    {step.note && (
                      <div class="mt-4 p-4 bg-paper-alt border-2 border-ink">
                        <p class="text-ink text-sm leading-relaxed">
                          <span class="font-black uppercase text-xs tracking-wider"><span aria-hidden="true">→</span> Note:</span> <span set:html={step.note}></span>
                        </p>
                      </div>
                    )}
                  </li>
                );
              })}
            </ol>
          )}
        </div>
      </div>
    </section>

    <!-- Sponsors Section -->
    <section id="sponsors" class="py-20 bg-dark-900">
      <div class="container mx-auto px-6">
        <h2 class="text-4xl md:text-5xl font-bold text-center mb-12 text-white">Big Thanks to our Sponsors and Supporters</h2>
        <div class="flex flex-col md:flex-row items-center justify-center gap-10 md:gap-16">
          <img
            src={`${baseUrl}BMFTR_logo.jpg`}
            alt="BMFTR"
            class="max-w-md w-full h-auto shadow-lg border-2 border-ink hover:translate-x-[-2px] hover:translate-y-[-2px] transition-transform duration-150"
          />
          <img
            src={`${baseUrl}PrototypeFund_logo_dark.png`}
            alt="PrototypeFund"
            class="max-w-sm w-full h-auto transition-shadow duration-300 border-0"
          />
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="bg-paper-footer border-t-2 border-ink py-12">
      <div class="container mx-auto px-6">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 mb-8">
          <div>
            <h4 class="text-xl font-bold mb-4 text-accent-cyan">MLOX</h4>
            <p class="text-gray-400 mb-4">Sovereign AI Infrastructure. Open by Design. Slothfully Simple.</p>
            <p class="text-sm text-gray-500">MLOX is open-source under the MIT license.</p>
          </div>
          <div>
            <h4 class="text-lg font-semibold mb-4 text-white">Resources</h4>
            <ul class="space-y-2">
              <li><a href="https://github.com/BusySloths/mlox" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-accent-cyan transition-colors">GitHub</a></li>
              <li><a href="/mlox/docs/" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-accent-cyan transition-colors">API Documentation</a></li>
