---
// News banner for important announcements
---

<div
  id="news-banner"
  class="fixed top-[72px] left-0 right-0 z-40 bg-accent-cyan"
  role="region"
  aria-label="News announcement"
  aria-live="polite"
>
  <div class="container mx-auto px-6 py-2">
    <div class="flex items-center justify-between gap-3">
      <div class="flex items-center gap-3 flex-1 justify-center text-center">
        <span aria-hidden="true" class="text-xl">⚡</span>
        <p class="text-paper-bright font-bold text-xs md:text-sm uppercase tracking-wide">
          <span class="font-black">News:</span> Our paper "MLOX: Open-Source MLOps for the Rest of Us" has been accepted by
          <a href="https://conf.researchr.org/home/cain-2026" target="_blank" rel="noopener noreferrer" class="underline decoration-2 hover:bg-black hover:text-white px-1">
            CAIN 2026
          </a>
          <span class="hidden sm:inline"> — the top AI Engineering conference.</span>
        </p>
        <span aria-hidden="true" class="text-xl">⚡</span>
      </div>
      <button
        id="close-banner"
        class="ml-2 text-paper-bright hover:bg-black hover:text-white transition-colors p-1 border border-black"
        aria-label="Close banner"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="square" stroke-linejoin="miter" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const banner = document.getElementById('news-banner');
    const closeButton = document.getElementById('close-banner');

    const bannerClosed = localStorage.getItem('news-banner-closed');
    if (bannerClosed === 'true') {
      banner?.classList.add('hidden');
      document.querySelector('main')?.classList.remove('pt-16');
    }

    closeButton?.addEventListener('click', () => {
      banner?.classList.add('hidden');
      localStorage.setItem('news-banner-closed', 'true');
      document.querySelector('main')?.classList.remove('pt-16');
    });
  });
</script>
