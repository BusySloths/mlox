apiVersion: v1
kind: ServiceAccount
metadata:
  name: @service_account_name
  namespace: @namespace
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: @binding_name
subjects:
  - kind: ServiceAccount
    name: @service_account_name
    namespace: @namespace
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: cluster-admin
