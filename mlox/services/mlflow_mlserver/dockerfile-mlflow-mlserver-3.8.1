# Minimal Debian base — no pre-installed Python. pyenv is the single source of truth
# for all Python versions, avoiding the dual-Python ambiguity of python:X.Y-slim images
# (which include both Docker's Python and Debian's system Python in the same container).
FROM debian:bookworm-slim

USER root

ENV PYENV_ROOT="/root/.pyenv"
ENV PATH="$PYENV_ROOT/shims:$PYENV_ROOT/bin:$PATH"
ENV PYTHONPATH=.

# Build dependencies for pyenv to compile any Python version from source.
RUN apt-get -y update && apt-get -y install --no-install-recommends \
    curl \
    bash \
    git \
    build-essential \
    pkg-config \
    libssl-dev \
    zlib1g-dev \
    libbz2-dev \
    libreadline-dev \
    libsqlite3-dev \
    libncursesw5-dev \
    libffi-dev \
    liblzma-dev \
    ca-certificates \
    xz-utils tk-dev \
    libgdbm-dev libgdbm-compat-dev \
    libdb-dev uuid-dev libexpat1-dev \
    && rm -rf /var/lib/apt/lists/*

RUN curl -s -L https://pyenv.run | bash

ENV PYENV_SHELL=bash
ENV HOME=/root

# Bootstrap Python: pre-installed so the startup script can immediately download
# model artifacts and read python_env.yaml without waiting for a compile step.
# Also serves as the fast path for models logged from Python 3.12.5 — pip install
# at startup will be a near no-op since mlflow/mlserver are already here.
RUN pyenv install 3.12.5 && pyenv global 3.12.5 && pyenv rehash

# Install mlflow + mlserver into the bootstrap Python.
# start_mlserver.sh re-runs these installs after switching to the model's Python,
# so models requiring a different version get a properly configured environment.
RUN pip install --no-cache-dir "mlflow==3.8.1" "mlflow[extras]==3.8.1"
RUN pip install --no-cache-dir "mlserver~=1.7.1" "mlserver-mlflow~=1.7.1"
RUN pip install --no-cache-dir "uvloop==0.21.0"

# Startup script: reads model's Python version, installs it via pyenv if needed,
# installs model requirements, then starts MLServer with --env-manager=local.
COPY start_mlserver.sh /root/start_mlserver.sh
RUN chmod +x /root/start_mlserver.sh
