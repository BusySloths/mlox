apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: @ingress_name
  namespace: @namespace
  annotations:
@annotations_block
spec:
  ingressClassName: traefik
  rules:
  - http:
      paths:
      - path: @path
        pathType: Prefix
        backend:
          service:
            name: @service_name
            port:
              number: @backend_port
