  margin-right: 1;
  background: #30374fff;
  border: round #6d789dff;
}

#confirm-enable-firewall {
  width: 1fr;
  background: #0e9455ff;
  border: round #8fe388ff;
}

#openbao-settings {
  height: auto;
  width: 1fr;
  padding: 0 1 1 1;
}

.openbao-section-title {
  height: 1;
  margin: 1 0 0 0;
  color: #8fe388ff;
  text-style: bold;
}

#openbao-status,
#openbao-help {
  height: auto;
  margin-bottom: 1;
}

#openbao-access-actions,
#openbao-application-form,
#openbao-application-actions,
#openbao-recovery-actions {
  height: 3;
