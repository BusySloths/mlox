LoginScreen {
  background: #061412ff;
  color: #e6edf7;
  margin: 0;
}

#login-shell {
  height: 1fr;
  width: 1fr;
  align: center middle;
}

.app-header {
  background: #0e9455ff;
  color: #e6edf7;
  text-style: bold;
}

#login-form {
  width: 76;
  height: auto;
  margin: 0 0 1 0;
  padding: 0 3 1 3;
  background: #0d2a24ff;
  border: round #74d17aff;
  color: #ffffff;
  layer: 1;
}

#login-logo {
  content-align: center middle;
  height: auto;
  color: #8fe388ff;
  text-style: bold;
}

#login-subtitle {
  content-align: center middle;
  height: auto;
  margin-bottom: 0;
  color: #a6c9bdff;
}

Input {
  background: #042c07ff;
  color: #e6edf7;
  border: round #e65516ff;  
}

#project {
  width: 68;
  min-height: 3;
  height: 3;
  padding: 0 1;
  margin: 0 0 0 0;
  color: #e6edf7;
}

#password {
  width: 68;
  min-height: 3;
  height: 3;
  padding: 0 1;
  margin: 0;
  color: #e6edf7;
}

#login-actions {
  layout: horizontal;
  width: 68;
  height: 3;
  margin-top: 0;
}

#login-loading-row {
  width: 68;
  height: auto;
  margin-top: 1;
  align-vertical: middle;
}

#login-loading-indicator {
  width: 4;
  height: 1;
}

#login-loading-label {
  width: 1fr;
  height: auto;
  margin-left: 1;
  color: #a6c9bdff;
}

Button {
  background: #cc19aeff;
  color: #e6edf7;
  border: round #f4e223ff;
  text-style: bold;
}

#login-btn {
  width: 33;
  min-height: 3;
  height: 3;
  content-align: center middle;
}

#create-btn {
  width: 33;
  min-height: 3;
  height: 3;
  content-align: center middle;
  margin-left: 1;
  background: #24406fff;
  border: round #69b7ffff;
  color: #ffffff;
}

#create-btn:hover {
  background: #305aa0ff;
}

#message {
  height: auto;
  color: #ff6b6b;
  margin-top: 1;
}

#main-area {
  layout: horizontal;
  height: 1fr;
}

#sidebar {
  width: 32;
  border: round #eccf2eff;
  padding: 0;
  margin-right: 1;
}

#detail-panel {
  layout: vertical;
  width: 1fr;
  height: 1fr;
  border: round #1bd6f3ff;
  padding: 0;
  min-height: 5;
  background: #062c19ff;
}

#upper-pane {
  layout: vertical;
  height: 1fr;
  min-height: 50%;
  padding: 1;
}

#project-reload-loading,
#server-add-loading,
#bundle-lifecycle-loading {
  height: auto;
  margin-bottom: 1;
  align-vertical: middle;
}

#project-reload-indicator,
#server-add-indicator,
#bundle-lifecycle-indicator {
  width: 4;
  height: 1;
}

#project-reload-label,
#server-add-label,
#bundle-lifecycle-label {
  width: 1fr;
  height: auto;
  margin-left: 1;
  color: #a6c9bdff;
}

#server-add-label,
#bundle-lifecycle-label {
  color: #f4e223ff;
}

#summary-pane {
  layout: horizontal;
  height: 1fr;
}

#app-log-drawer {
  height: 14;
  min-height: 8;
  background: #031410ff;
  padding: 0;
  margin: 0;
  layout: vertical;
  width: 1fr;
}

#app-log-output {
  height: 1fr;
  width: 1fr;
  background: #031410ff;
}

#main-tabs {
  height: 1fr;
}

#overview-tab,
#server-templates-tab,
#secret-manager-tab,
#firewall-tab,
#monitor-tab,
#models-tab,
#service-templates-tab,
#service-tui-tab {
  height: 1fr;
}

#overview-scroll,
.template-scroll-wrapper {
  height: 1fr;
  width: 1fr;
  overflow-y: auto;
}

#service-tui-container {
  height: 1fr;
  width: 1fr;
}

#server-template-panel,
#service-template-panel,
#secret-manager-panel,
#firewall-panel,
#monitor-panel,
#models-panel {
  height: 1fr;
  width: 1fr;
  layout: vertical;
}

#models-content {
  height: 1fr;
  width: 1fr;
}

#models-metrics {
  height: 5;
  margin-bottom: 1;
}

.model-metric {
  width: 1fr;
  height: 5;
  margin-right: 1;
  padding: 0 2;
  content-align: center middle;
  border: round #35635bff;
  background: #10211fff;
}

#models-metric-available {
  margin-right: 0;
  border: round #61d394ff;
}

#models-browser {
  height: 2fr;
  width: 1fr;
  margin-bottom: 1;
}

#model-registry-table {
  width: 34;
  height: 1fr;
  margin-right: 1;
  border: round #3ba55d;
}

#model-endpoint-table {
  width: 2fr;
  height: 1fr;
  margin-right: 1;
  border: round #1bd6f3ff;
}

#served-model-table {
  width: 2fr;
  height: 1fr;
  border: round #8fe388ff;
}

#model-example-actions {
  height: 3;
  margin-bottom: 0;
}

#model-example-title {
  width: 1fr;
  content-align: left middle;
  color: #a6c9bdff;
  text-style: bold;
}

#load-model-example,
#call-model-example,
#copy-model-example {
  width: auto;
  min-width: 20;
  margin-left: 1;
}

#load-model-example {
  background: #0e9455ff;
  border: round #8fe388ff;
}

#copy-model-example {
  background: #24406fff;
  border: round #69b7ffff;
}

#call-model-example {
  background: #3b3f8fff;
  border: round #9aa7ffff;
}

#model-example {
  width: 1fr;
  height: 12;
  border: round #69b7ffff;
}

ModelCallResultDialog {
  align: center middle;
}

#model-call-result-dialog {
  width: 96;
  height: 34;
  padding: 1 2;
  background: #17214aff;
  border: round #69b7ffff;
}

#model-call-result-title {
  width: 1fr;
  height: 1;
  content-align: center middle;
  text-style: bold;
  color: #f4e223ff;
}

#model-call-result-body {
  width: 1fr;
  height: 1fr;
  margin-top: 1;
  border: round #9aa7ffff;
}

#model-call-result-actions {
  height: 3;
  margin-top: 1;
  align-horizontal: center;
}

#firewall-content {
  height: 1fr;
  width: 1fr;
}

#firewall-summary {
  height: auto;
  margin-bottom: 1;
}

#firewall-actions {
  height: 3;
  margin-bottom: 1;
}

#firewall-actions Button {
  width: auto;
  min-width: 18;
  margin-right: 1;
}

#refresh-firewalls {
  background: #24406fff;
  border: round #69b7ffff;
}

#enable-firewall {
  background: #0e9455ff;
  border: round #8fe388ff;
}

#disable-firewall {
  background: #8d1b1bff;
  border: round #ff7676ff;
}

#firewall-browser {
  height: 1fr;
  width: 1fr;
}

#firewall-table {
  width: 50;
  height: 1fr;
  margin-right: 1;
}

#firewall-detail-pane {
  width: 1fr;
  height: 1fr;
}

#firewall-detail {
  width: 1fr;
  height: auto;
  margin-bottom: 1;
}

#firewall-raw-status {
  width: 1fr;
  height: 1fr;
  border: round #69b7ffff;
}

#monitor-content {
  height: 1fr;
  width: 1fr;
}

#monitor-metrics {
  height: 5;
  margin-bottom: 1;
}

.monitor-metric {
  width: 1fr;
  height: 5;
  margin-right: 1;
  padding: 0 2;
  content-align: center middle;
  border: round #35635bff;
  background: #10211fff;
}

#monitor-metric-data {
  margin-right: 0;
  border: round #61d394ff;
}

#monitor-actions {
  height: 3;
  margin-bottom: 1;
}

#monitor-title {
  width: 1fr;
  content-align: left middle;
  color: #a6c9bdff;
  text-style: bold;
}

#refresh-monitor {
  width: auto;
  min-width: 18;
  background: #24406fff;
  border: round #69b7ffff;
}

#monitor-table {
  height: 2fr;
  width: 1fr;
  border: round #1bd6f3ff;
}

#monitor-service-detail {
  height: 2fr;
  width: 1fr;
  margin-top: 1;
  border: round #35635bff;
}

EnableFirewallDialog {
  align: center middle;
}

#enable-firewall-dialog {
  width: 78;
  height: auto;
  padding: 1 2;
  background: #17214aff;
  border: round #69b7ffff;
}

#enable-firewall-title {
  width: 1fr;
  content-align: center middle;
  text-style: bold;
  color: #f4e223ff;
}

#enable-firewall-help {
