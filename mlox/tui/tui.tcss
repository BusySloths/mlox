}

#openbao-refresh-apps {
  background: #24406fff;
  border: round #69b7ffff;
}

#openbao-rotate-client,
#openbao-unseal {
  background: #9d7a09ff;
  border: round #f4e223ff;
  color: #ffffff;
}

#openbao-revoke-app {
  background: #8d1b1bff;
  border: round #ff7676ff;
}

#openbao-application-table {
  height: 16;
  margin-bottom: 1;
}

#secret-manager-content {
