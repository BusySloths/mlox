}

#remove-bundle-dialog {
  width: 60;
  height: auto;
  margin: 2 4;
  padding: 1 2;
  background: #0d2a24ff;
  border: round #ff8a8a;
}

#remove-bundle-title {
  height: auto;
  content-align: center middle;
  text-style: bold;
  color: #ffd7d7;
  margin-bottom: 1;
}

#remove-bundle-message {
  height: auto;
  color: #e6edf7;
  margin-bottom: 1;
}

#remove-bundle-actions {
  height: auto;
  align-horizontal: right;
}

#cancel-remove-bundle {
  width: auto;
}

#confirm-remove-bundle {
  width: auto;
  margin-left: 1;
  background: #9d2222;
  border: round #ff8a8a;
  color: #ffffff;
}

#confirm-remove-bundle:hover {
  background: #bd2f2f;
}

TemplateSetupDialog {
  align: center middle;
}

#template-setup-dialog {
  width: 72;
  height: auto;
  max-height: 40;
  margin: 2 4;
  padding: 1 2;
  background: #0d2a24ff;
  border: round #74d17aff;
}

#template-setup-title {
  height: auto;
  content-align: center middle;
  text-style: bold;
  color: #e6edf7;
  margin-bottom: 1;
}

#template-setup-description,
.template-field-help {
  height: auto;
  color: #a6c9bdff;
}

#template-setup-error {
  height: auto;
  color: #ff8585;
  margin: 1 0;
}

#template-setup-fields {
  height: auto;
  max-height: 26;
}

.template-field-label {
  height: auto;
  margin-top: 1;
  color: #e6edf7;
}

.template-field-multiline {
  height: 7;
}

#template-setup-actions {
  height: auto;
  margin-top: 1;
  align-horizontal: right;
}

#cancel-template-setup {
  width: auto;
}

#confirm-template-setup {
  width: auto;
  margin-left: 1;
  background: #0e9455ff;
  border: round #8fe388ff;
  color: #ffffff;
}

#confirm-template-setup:hover {
  background: #12b86aff;
}

#server-credentials {
  height: auto;
  margin-top: 1;
  color: #e6edf7;
}

#credential-copy-buttons {
  margin-top: 1;
}

#activity-tabs {
  height: 1fr;
  min-height: 50%;
}

#activity-container {
  border: round #2fa527ff;
  background: #13270fff;
  padding: 1;
  margin-top: 1;
}

#logs-tab,
#history-tab {
  padding: 1;
}

#selection-logs,
#selection-history {
  layout: vertical;
  height: 1fr;
}

#history-table {
  margin-top: 1;
}

#history-status {
  margin-top: 1;
}

.section-title {
  text-style: bold;
  color: #e6edf7;
  margin-bottom: 1;
}

#log-controls {
  layout: horizontal;
  margin-bottom: 1;
  align-horizontal: left;
  align-vertical: middle;
  height: auto;
}

#log-label {
  width: 1fr;
  min-width: 20;
}

#log-tail,
#log-fetch {
  margin-left: 1;
}

#log-tail {
  width: 12;
}

#log-fetch {
  width: auto;
  min-width: 8;
}

#log-output,
#log-status {
  margin-top: 1;
}

#log-output {
  height: 1fr;
  min-height: 10;
  border: round #1bd6f3ff;
  background: #031410ff;
}

#history-table {
  height: 1fr;
  min-height: 10;
  border: round #1bd6f3ff;
}

#log-status,
#history-status {
  color: #94a3b8;
  margin-top: 1;
}

Tree {
  height: 100%;
  background: #052628ff;
  scrollbar_color: #c21cbfff;              /* thumb color */
  scrollbar_color_hover: #2fa527ff;        /* thumb on hover */
  scrollbar_color_active: #f0e55cff; 
  scrollbar_background: #052628ff;         /* track background */ 
  scrollbar_background_hover: #05241bff;   /* track on hover */
  scrollbar_background_active: #0c2116ff;  /* track while dragging */
  scrollbar_size_horizontal: 1; 
}

#main-panel {
  border: round #c21cbfff;
  padding: 0;
  height: 1fr;
  background: #1f2503ff;
}

#home-content {
  margin-top: 0;
}

#selection-title {
  text-style: bold;
  color: #e6edf7;
}

#selection-state {
  color: #e6edf7;
}

#otel-telemetry-status {
  margin-bottom: 1;
  color: #94a3b8;
}

.otel-resource-row {
  height: auto;
  margin-bottom: 1;
}

.otel-resource-card {
  width: 1fr;
  margin-right: 1;
}

#otel-telemetry-summary {
  margin-top: 1;
}
