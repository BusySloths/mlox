}

#template-add-indicator {
  display: none;
  width: 4;
  height: 1;
  margin-left: 1;
}

#template-add-status {
  display: none;
  width: 1fr;
  height: auto;
  margin-left: 1;
  color: #a6c9bdff;
}

#selection-overview {
  margin-right: 1;
}

#selection-overview,
#selection-project-actions,
#selection-server-actions,
#selection-service-actions,
#selection-server-info,
#selection-logs,
#selection-history {
